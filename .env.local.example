# ---------------------------------------------------------------------------
# Notify Me Admin Dashboard — database connection (READ ONLY)
# Copy this file to ".env.local" and fill in the values.
# ---------------------------------------------------------------------------

DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=

# Optional: the specific database/schema to use.
# Leave blank to auto-detect the first non-system schema on the server.
DB_NAME=

# RDS uses TLS. Leave as "true" unless your server explicitly does not support it.
DB_SSL=true
