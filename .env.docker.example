# Copy this file to ".env" (next to docker-compose.yml) and edit.
# docker compose automatically reads ".env".

# Local MySQL root password (used by the dashboard + importer)
MYSQL_ROOT_PASSWORD=root

# Google Drive: rclone remote name + the SHARED FOLDER ID that holds the daily
# .sql dumps. The importer picks the NEWEST file in this folder each run and
# skips if it hasn't changed since the last import.
GDRIVE_REMOTE=gdrive
GDRIVE_FOLDER_ID=11hiUAwq5W4XW1hIAmETKHnHi5tkHjVI3

# When the daily import runs (24h clock, in the TZ below)
IMPORT_HOUR=9
IMPORT_MINUTE=0
TZ=Asia/Kolkata

# Import immediately when the stack first starts (recommended the first time)
IMPORT_ON_START=true

# --- Email sending (optional; enables the Send buttons in Email Outreach) ---
# Leave blank to keep sending disabled (recommend/preview still work).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
